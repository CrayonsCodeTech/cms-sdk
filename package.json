{
  "name": "@crayons/cms-sdk",
  "version": "0.3.0",
  "description": "CMS SDK for fetching data and shared types",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "prepare": "npm run build",
    "lint": "eslint src/**/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cms",
    "sdk",
    "nextjs",
    "fetch"
  ],
  "author": "Crayons",
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lucide-react": "^0.400.0"
  },
  "dependencies": {
    "lucide-react": "^0.400.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
}
